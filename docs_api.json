            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                },
                "user": {
                    "type": "object",
                    "properties": {
                        "email": {
                            "type": "string"
                        },
                        "full_name": {
                            "type": "string"
                        },
                        "id": {
                            "type": "string"
                        },
                        "role": {
                            "type": "string"
                        }
                    }
                }
